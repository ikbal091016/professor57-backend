NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:3000

MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/professor57

JWT_ACCESS_SECRET=replace-with-long-random-string
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

RESEND_API_KEY=replace-with-resend-key
EMAIL_FROM="Professor57 <no-reply@professor57.com>"

STRIPE_SECRET_KEY=sk_test_replace-me
STRIPE_WEBHOOK_SECRET=whsec_replace-me

# Mux — used for paid-lecture video hosting with signed, expiring playback.
# Free-preview lectures can stay on plain YouTube; see README Phase 4 notes.
MUX_TOKEN_ID=replace-with-mux-token-id
MUX_TOKEN_SECRET=replace-with-mux-token-secret
MUX_SIGNING_KEY_ID=replace-with-mux-signing-key-id
MUX_SIGNING_KEY_PRIVATE=replace-with-mux-signing-key-base64
MUX_WEBHOOK_SECRET=replace-with-mux-webhook-signing-secret

COOKIE_DOMAIN=localhost
